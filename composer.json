{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "fadez/sneakpeek",
    "type": "project",
    "description": "Secure, one-time secret sharing made simple.",
    "keywords": [],
    "license": "proprietary",
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13.6",
        "laravel/pennant": "^1.23",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3.1",
        "pusher/pusher-php-server": "^7.2.7"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.2.8",
        "larastan/larastan": "^3.9.6",
        "laravel/boost": "^2.4.5",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.29.1",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.6.3",
        "pestphp/pest-plugin-browser": "^4.3.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install --no-interaction --no-progress",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@install:sqlite",
            "@php artisan migrate --force",
            "@build",
            "@install:playwright"
        ],
        "install:playwright": "npx playwright install --with-deps",
        "install:reverb": "@php artisan reverb:install",
        "install:sqlite": "@php -r \"!file_exists('database/database.sqlite') && touch('database/database.sqlite');\"",
        "build": [
            "node -e \"require('fs').rmSync('node_modules', { recursive: true, force: true })\"",
            "npm install",
            "npm run build"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u",
            "@build"
        ],
        "lint": [
            "npm run lint",
            "pint --parallel",
            "rector --clear-cache"
        ],
        "test:lint": [
            "npm run test:lint",
            "pint --parallel --test",
            "rector --dry-run --clear-cache"
        ],
        "test:types": "phpstan",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:unit": "pest --parallel",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:type-coverage",
            "@test:unit"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi",
            "@update:requirements"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
